# -----------------------------
# SolarWill Kernel: Week 1 env
# -----------------------------

# Week 1 default:
# start with stub, then switch to gemini or ollama on Day 3.
SOLARWILL_BACKEND=gemini

# Trace / debug
SOLARWILL_PROMPT_VERSION=v0.1
SOLARWILL_DEBUG=false
SOLARWILL_SAVE_TRACE=true
SOLARWILL_TRACE_DIR=artifacts/traces
SOLARWILL_TIMEOUT_SECONDS=30

# Constraint mode
SOLARWILL_CONSTRAINT_MODE=basic

# -----------------------------
# Gemini
# -----------------------------
GEMINI_API_KEY=
SOLARWILL_GEMINI_MODEL=gemini-2.0-flash

# -----------------------------
# Ollama
# -----------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b